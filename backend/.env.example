PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solutionchallenge
DB_SSL_ENABLED=true
DB_SSL_REJECT_UNAUTHORIZED=false
AUTH_PROVIDER=firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_WEB_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_LLM_HELPER_ENABLED=false
OPENAI_LLM_TIMEOUT_MS=15000
OPENAI_LLM_MIN_FIELD_CONFIDENCE=0.74
OPENAI_LLM_INCLUDE_IMAGE=true
STORAGE_BACKEND=local
UPLOADS_DIR=./uploads
LOCAL_ASSET_BASE_URL=/uploads
SUPABASE_STORAGE_BUCKET=report-photos
DEFAULT_ADMIN_EMAIL=admin@example.com
